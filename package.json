{
  "name": "zotero-meta-refresh",
  "type": "module",
  "version": "0.1.0",
  "description": "Batch-refresh Zotero item metadata from CrossRef, OpenAlex, Semantic Scholar and DBLP, with a preview-confirm flow, field whitelist, preprint upgrade and old-value backup to Extra.",
  "config": {
    "addonName": "Zotero Metadata Refresh",
    "addonID": "metarefresh@zhibo.ark0",
    "addonRef": "metarefresh",
    "addonInstance": "MetaRefresh",
    "prefsPrefix": "extensions.zotero.metarefresh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhiboRao/zotero-meta-refresh.git"
  },
  "author": "Zhibo (船长) & Ark0号机",
  "homepage": "",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "postbuild": "mkdir -p dist && cp .scaffold/build/*.xpi dist/",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
